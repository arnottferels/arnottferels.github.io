@misc{ferels_urban_flow_2023,
  title={Urban Flow Simulation},
  abstract={Podomoro City, a large urban complex in West Jakarta, combines luxury and mid-to-high-end apartments, the Pullman Hotel, and the Tribeca Arcade, connecting the Central Park Mall to nearby buildings. This study uses Computational Fluid Dynamics (CFD) to analyze wind flow through the development, focusing on how wind interacts with the structures and affects the surrounding environment. By simulating airflow across the site, the study offers insights on how to mitigate potential issues in future iterations of the design, with a focus on optimizing airflow, improving comfort, and minimizing scalable environmental impacts.},
  author={Ferels, Arnott},
  keywords={Urban simulation,Computational Fluid Dynamics,Wind flow modeling,Environmental impact,CFD},
}